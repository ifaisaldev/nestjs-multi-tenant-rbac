# ===================================================
# MULTI-TENANT RBAC SYSTEM - ENVIRONMENT CONFIGURATION
# ===================================================

# Application
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1
APP_NAME=NestJS Multi-Tenant RBAC

# Database - PostgreSQL 16
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/multitenant_rbac?schema=public"
# Schema-per-tenant requires dynamic schema switching
# The DATABASE_URL serves as the base connection

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_REFRESH_EXPIRES_IN=7d

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TTL=3600

# RabbitMQ
RABBITMQ_URL=amqp://admin:admin@localhost:5672
RABBITMQ_EXCHANGE=multitenant_events
RABBITMQ_QUEUE_PREFIX=nest_rbac

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# Email (for verification and password reset)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@your-domain.com

# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:3001
CORS_CREDENTIALS=true

# Security
BCRYPT_SALT_ROUNDS=12
SESSION_SECRET=your-session-secret-change-in-production

# Swagger
SWAGGER_ENABLED=true
SWAGGER_TITLE=Multi-Tenant RBAC API
SWAGGER_DESCRIPTION=Production-grade RBAC with multi-tenancy
SWAGGER_VERSION=1.0

# GraphQL
GRAPHQL_PLAYGROUND=true
GRAPHQL_DEBUG=true
GRAPHQL_SCHEMA_PATH=src/schema.gql

# Logging
LOG_LEVEL=debug
LOG_PRETTY_PRINT=true

# Multi-Tenancy
DEFAULT_TENANT_SCHEMA=tenant_default
TENANT_HEADER_NAME=X-Tenant-ID
